<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= myTitle %></title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/contactAnimation.css">
</head>
<body>

    <div class="finalClass">
        <div class="headerClass">
            <%- include('partials/hamburgerMenu') %>
        </div>

        <main class="mainClass contact-main">
            <div class="final-container">
                
                <div class="image-container">
                    <img src="/images/rawraboutme.png" alt="kitty on top of mountain" id="contact-img">
                </div>

                <div class="contact-form-container">
                    <h2 class="contact-heading">// INITIATE_CONTACT</h2>
                    
                    <form id="contactForm" action="/contact" method="POST">
                        <div class="form-group">
                            <label for="name">NAME</label>
                            <input type="text" id="name" name="name" placeholder="Enter your name here" required>
                            <span class="error-message" id="nameError"></span>
                        </div>

                        <div class="form-group">
                            <label for="email">EMAIL</label>
                            <input type="email" id="email" name="email" placeholder="Enter your email" required>
                            <span class="error-message" id="emailError"></span>
                        </div>

                        <div class="form-group">
                            <label for="phone">PHONE</label>
                            <input type="tel" id="phone" name="phone" placeholder="Enter your phone number" required>
                            <span class="error-message" id="phoneError"></span>
                        </div>

                        <div class="form-group">
                            <label for="message">MESSAGE</label>
                            <textarea id="message" name="message" placeholder="Enter your message..." rows="5" required></textarea>
                            <span class="error-message" id="messageError"></span>
                        </div>

                        <button type="submit" class="submit-button">SEND_MESSAGE</button>
                    </form>
                </div>

            </div>
        </main>

        <div class="footerClass">
            <%- include('partials/footer') %>
        </div>
    </div>

</body>
</html>