<div class="mobile-nav-wrapper">
    <button class="burger-trigger" aria-label="Toggle Menu" aria-expanded="false">
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
    </button>

    <nav class="mobile-drawer">
        <div class="drawer-header">
            <span>MENU.EXE</span>
            <button class="drawer-close">&times;</button>
        </div>

        <div class="drawer-content">
            <div class="drawer-section">
                <h3>PROJECTS</h3>

                <% projects.forEach((project, index)=> { %>
                    <% const repo=repos[index]; %>

                        <button type="button" class="project-btn mobile-project-btn" data-preview="<%= project.img %>"
                            data-title="<%= repo ? repo.name : project.title %>"
                            data-description="<%= repo ? repo.description : '' %>"
                            data-live="<%= repo ? repo.live_code_url : '' %>"
                            data-github="<%= repo ? repo.repo_url : '' %>"
                            data-images='<%- JSON.stringify(repo ? repo.images : []) %>'>

                            <%= project.title %>

                        </button>

                        <% }) %>

            </div>

            <div class="drawer-section">
                <h3> NAVIGATION</h3>
                <a href="/aboutme">About Me</a>
                <a href="https://github.com/Beltag-Paula" target="_blank" rel="noopener noreferrer">GitHub</a>
                <a href="/blog">Blog</a>
                <a href="https://www.youtube.com/@pumabytes" target="_blank" rel="noopener noreferrer">YouTube</a>
                <a href="https://www.linkedin.com/in/paula-beltag-6976781b8/" target="_blank"
                    rel="noopener noreferrer">LinkedIn</a>
                <a href="/contact">Contact</a>
            </div>
        </div>
    </nav>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const trigger = document.querySelector(".burger-trigger");
        const closeBtn = document.querySelector(".drawer-close");
        const drawer = document.querySelector(".mobile-drawer");

        function toggleMenu() {
            const isOpen = drawer.classList.toggle("is-open");
            trigger.setAttribute("aria-expanded", isOpen);
            // Prevents the background content from scrolling when menu is open
            document.body.style.overflow = isOpen ? "hidden" : "";
        }

        trigger.addEventListener("click", toggleMenu);
        closeBtn.addEventListener("click", toggleMenu);
    });
</script>