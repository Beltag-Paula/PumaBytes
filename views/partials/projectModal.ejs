
<div id="projectModal" class="project-modal hidden">

    <div class="project-modal-card">

        <button id="closeModal" class="project-modal-close">
            ✕
        </button>

        <h2 id="modalTitle"></h2>

        <p id="modalDescription"></p>

        <div id="modalGallery" class="modal-gallery"></div>

        <div class="project-modal-actions">

            <a id="liveButton" class="modal-button" target="_blank">
                Live Demo
            </a>

            <a id="githubButton" class="modal-button" target="_blank">
                GitHub
            </a>

        </div>

    </div>

</div>


<div id="imageLightbox" class="image-lightbox hidden">

    <button id="closeLightbox" class="lightbox-close">✕</button>

    <button id="prevLightbox" class="lightbox-nav lightbox-prev">◀</button>

    <img id="lightboxImage" src="" alt="Project screenshot">

    <button id="nextLightbox" class="lightbox-nav lightbox-next">▶</button>

</div>
